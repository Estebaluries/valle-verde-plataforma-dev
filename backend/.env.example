# CONFIGURACIÓN TEMPLATE PARA INMOBILIARIA VALLE VERDE
# Copia este archivo a .env.local.dev o .env.production según necesites
# NO commitees archivos .env con secretos reales al repositorio

# ==================== FLASK ====================
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# ==================== SUPABASE ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-public-anon-key

# ==================== JWT ====================
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== CORS ====================
# URLs permitidas para requests desde el frontend
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5173

# ==================== TENANT ====================
# Valle Verde tenant ID (UUID)
# En futuro: se leerá desde header X-Tenant-ID o desde JWT claims
TENANT_ID=123e4567-e89b-12d3-a456-426614174000

# ==================== EMAIL (SENDGRID - OPCIONAL) ====================
# Para notificaciones de nuevos leads, visitas, ofertas
# SENDGRID_API_KEY=your-sendgrid-api-key
# SENDGRID_FROM_EMAIL=notificaciones@valleverde.com

# ==================== SMS (TWILIO - OPCIONAL) ====================
# Para alertas vía SMS a agentes
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ==================== LOGGING ====================
LOG_LEVEL=INFO
# LOG_FILE=/var/log/valle-verde/app.log

# ==================== OTRAS CONFIGURACIONES ====================
# Aquí agregar confgs específicas según necesidad
